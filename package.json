{
  "name": "crm-web",
  "version": "0.0.1",
  "description": "DigiChat CRM Web — Next.js 15 + Tailwind 4 + shadcn/ui + TanStack Query + Kubb",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write --no-error-on-unmatched-pattern \"{app,components,lib,hooks,stores}/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"{app,components,lib,hooks,stores}/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:api": "kubb generate",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.6",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@kubb/cli": "^4.37.5",
    "@kubb/plugin-client": "^4.37.5",
    "@kubb/plugin-oas": "^4.37.5",
    "@kubb/plugin-react-query": "^4.37.5",
    "@kubb/plugin-ts": "^4.37.5",
    "@kubb/plugin-zod": "^4.37.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
